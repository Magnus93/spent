{
	"plugins": [
		"@typescript-eslint",
		"prettier",
		"simple-import-sort"
	],
	"extends": [
		"eslint:recommended",
		"plugin:@typescript-eslint/eslint-recommended",
		"plugin:@typescript-eslint/recommended",
		"plugin:prettier/recommended"
	],
	"rules": {
		"curly": [
			"error",
			"all"
		],
		"prettier/prettier": [
			"warn",
			{
				"semi": false,
				"singleQuote": false,
				"tabWidth": 2,
				"trailingComma": "es5"
			}
		],
	}
}
