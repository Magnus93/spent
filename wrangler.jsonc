{
	"name": "spent",
	"main": "./index.ts",
	"compatibility_date": "2026-04-14",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"dev": {
		"port": 8787
	},
	"env": {
		"local": {
			"hyperdrive": [
				{
					"binding": "hyperdrive",
					"id": "",
					"localConnectionString": "postgres://spent_app:Soodee5O@localhost:5432/spent"
				}
			],
			"vars": {
				"system": "local",
				"adminSecret": "adminSecret",
				"issuer": "pax2pay",
				"mockbankUrl": "local"
			}
		}
	}
}
